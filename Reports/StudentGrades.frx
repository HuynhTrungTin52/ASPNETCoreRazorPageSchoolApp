      <TableDataSource Name="Table" Alias="StudentGrades" DataType="System.Int32" Enabled="true" SelectCommand="SELECT &#10;    s.StudentID,&#10;    s.FirstName + ' ' + s.LastName AS FullName,&#10;    e.Grade,&#10;    c.Title AS CourseTitle&#10;FROM &#10;    Students s&#10;INNER JOIN &#10;    Enrollments e ON s.StudentID = e.StudentID&#10;INNER JOIN &#10;    Courses c ON e.CourseID = c.CourseID&#10;ORDER BY &#10;    s.LastName, s.FirstName, c.Title;">
        <Column Name="StudentID" DataType="System.Int32"/>
        <Column Name="FullName" DataType="System.String"/>
        <Column Name="Grade" DataType="System.Decimal"/>
        <Column Name="CourseTitle" DataType="System.String"/>
      </TableDataSource>
    </MsSqlDataConnection>
